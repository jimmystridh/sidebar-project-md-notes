{
	"name": "sidebar-project-md-notes",
	"displayName": "Sidebar Project MD Notes",
	"description": "Markdown notes in the sidebar, synced with your project files",
	"version": "1.0.2",
	"publisher": "JimmyStridh",
	"author": {
		"email": "sidebar-project-md-notes-vsix@stridh.nu",
		"name": "Jimmy Stridh",
		"url": "https://github.com/JimmyStridh"
	},
	"license": "GPL-3.0-or-later",
	"icon": "images/icon.png",
	"repository": {
		"url": "https://www.github.com/JimmyStridh/sidebar-markdown-notes",
		"type": "git"
	},
	"keywords": [
		"markdown",
		"notes",
		"view",
		"sidebar",
		"github",
		"flavored",
		"todo",
		"checklist"
	],
	"engines": {
		"vscode": "^1.50.0"
	},
	"extensionKind": [
		"ui",
		"workspace"
	],
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:sidebar-project-md-notes.resetData",
		"onCommand:sidebar-project-md-notes.openNotesFile",
		"onView:sidebarProjectMdNotes.webview"
	],
	"main": "./out/extension.js",
	"contributes": {
		"views": {
			"explorer": [
				{
					"type": "webview",
					"id": "sidebarProjectMdNotes.webview",
					"name": "Project Notes"
				}
			]
		},
		"commands": [
			{
				"command": "sidebar-project-md-notes.resetData",
				"category": "Project Notes",
				"title": "Reset notes"
			},
			{
				"command": "sidebar-project-md-notes.openNotesFile",
				"category": "Project Notes",
				"title": "Open notes file",
				"icon": "$(go-to-file)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "sidebar-project-md-notes.openNotesFile",
					"group": "navigation@0",
					"when": "view == sidebarProjectMdNotes.webview"
				}
			]
		},
		"configuration": [
			{
				"title": "Project Notes",
				"properties": {
					"sidebar-project-md-notes.leftMargin": {
						"type": "boolean",
						"default": false,
						"description": "Whether or not a left margin should be added to the main view. To align it with other elements"
					}
				}
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"webpack": "webpack --mode development",
		"webpack-dev": "webpack --mode development --watch",
		"test-compile": "tsc -p ./",
		"compile": "tsc -p ./",
		"lint": "eslint src --ext ts",
		"watch": "tsc -p ./ --watch",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js",
		"deploy": "npx @vscode/vsce publish",
		"package": "npx @vscode/vsce package"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/marked": "^1.1.0",
		"@types/mocha": "^8.0.0",
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.50.0",
		"@typescript-eslint/eslint-plugin": "^4.1.1",
		"@typescript-eslint/parser": "^4.1.1",
		"@vscode/vsce": "^3.6.0",
		"eslint": "^7.9.0",
		"eslint-config-airbnb-base": "^14.2.0",
		"eslint-config-prettier": "^6.15.0",
		"eslint-plugin-import": "^2.22.1",
		"eslint-plugin-prettier": "^3.1.4",
		"glob": "^7.1.6",
		"mocha": "^11.7.2",
		"prettier": "^2.1.2",
		"ts-loader": "^8.0.11",
		"typescript": "^4.0.2",
		"vscode-test": "^1.4.0",
		"webpack": "^5.4.0",
		"webpack-cli": "^4.2.0"
	},
	"dependencies": {
		"dompurify": "^3.2.6",
		"lodash": "^4.17.21",
		"marked": "^16.2.1"
	}
}
